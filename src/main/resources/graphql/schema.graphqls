type Query {
    _empty: String
}

type Mutation {
    _empty: String
}

type NotificacionHotel {
    id: ID!
    mensaje: String!
    modulo: String!
}

type Subscription {
    # El frontend se suscribirá aquí para recibir notificaciones en tiempo real
    notificacionesSistema: NotificacionHotel!
}